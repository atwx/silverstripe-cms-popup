{
  "name": "silverstripe-cms-popup",
  "version": "1.0.0",
  "description": "Generic CMS modal popup for SilverStripe 6",
  "scripts": {
    "build": "NODE_ENV=production webpack --mode production --bail --progress",
    "dev": "NODE_ENV=development webpack --progress",
    "watch": "NODE_ENV=development webpack --watch --progress",
    "lint": "eslint client/src/",
    "lint:fix": "eslint client/src/ --fix",
    "format": "prettier --write 'client/src/**/*.js'",
    "format:check": "prettier --check 'client/src/**/*.js'",
    "stylelint": "stylelint 'client/src/scss/**/*.scss'",
    "stylelint:fix": "stylelint 'client/src/scss/**/*.scss' --fix",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@silverstripe/webpack-config": "^3",
    "webpack": "^5.74.0",
    "webpack-cli": "^5.0.0",
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^15",
    "prettier": "^3",
    "stylelint": "^16",
    "stylelint-config-standard-scss": "^13",
    "@babel/preset-env": "^7",
    "@babel/preset-react": "^7",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "babel-jest": "^29",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "react": "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  }
}
